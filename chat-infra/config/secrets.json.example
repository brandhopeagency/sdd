{
  "project_id": "your-gcp-project-id",
  "iam_members": [
    "serviceAccount:PROJECT_NUMBER-compute@developer.gserviceaccount.com"
  ],
  "secrets": [
    {
      "name": "db-password",
      "description": "Cloud SQL database password for the chat application",
      "auto_generate": false,
      "github_secret_name": "DATABASE_URL",
      "github_transform": "database_url"
    },
    {
      "name": "jwt-secret",
      "description": "JWT signing secret for access tokens",
      "auto_generate": true,
      "generate_length": 64,
      "github_secret_name": "JWT_SECRET",
      "github_transform": "none"
    },
    {
      "name": "jwt-refresh-secret",
      "description": "JWT signing secret for refresh tokens",
      "auto_generate": true,
      "generate_length": 64,
      "github_secret_name": "JWT_REFRESH_SECRET",
      "github_transform": "none"
    },
    {
      "name": "gmail-client-id",
      "description": "Google OAuth 2.0 client ID for Gmail API (email sending)",
      "auto_generate": false,
      "github_secret_name": null,
      "github_transform": "none"
    },
    {
      "name": "gmail-client-secret",
      "description": "Google OAuth 2.0 client secret for Gmail API",
      "auto_generate": false,
      "github_secret_name": "GMAIL_CLIENT_SECRET",
      "github_transform": "none"
    },
    {
      "name": "gmail-refresh-token",
      "description": "Google OAuth 2.0 refresh token for Gmail API",
      "auto_generate": false,
      "github_secret_name": "GMAIL_REFRESH_TOKEN",
      "github_transform": "none"
    },
    {
      "name": "gcp-wif-provider",
      "description": "Workload Identity Federation provider path for GitHub Actions",
      "auto_generate": false,
      "github_secret_name": "GCP_WIF_PROVIDER",
      "github_transform": "none"
    },
    {
      "name": "redis-host",
      "description": "Memorystore for Redis instance host IP address",
      "auto_generate": false,
      "github_secret_name": "REDIS_HOST",
      "github_transform": "none"
    },
    {
      "name": "redis-port",
      "description": "Memorystore for Redis instance port (default 6379)",
      "auto_generate": false,
      "github_secret_name": "REDIS_PORT",
      "github_transform": "none"
    }
  ]
}
