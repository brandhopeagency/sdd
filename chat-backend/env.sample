# ============================================
# Chat Application Backend Configuration
# Copy this file to .env and fill in your values
# ============================================

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============================================
# Feature flags
# ============================================
# Default: true (guest chat enabled). Set to "false" to require authentication for all chat endpoints.
ALLOW_GUEST_ACCESS=true

# ============================================
# Database (PostgreSQL via Cloud SQL)
# ============================================
# For local development with Cloud SQL Proxy:
DATABASE_URL=postgresql://chat_user:YOUR_PASSWORD@localhost:5432/chat_app

# For Cloud Run (Unix socket connection):
# DATABASE_URL=postgresql://chat_user:YOUR_PASSWORD@/chat_app?host=/cloudsql/PROJECT_ID:REGION:chat-db

# ============================================
# JWT Authentication
# ============================================
# Generate secrets: openssl rand -base64 32
JWT_SECRET=your-32-character-secret-here-change-this
JWT_REFRESH_SECRET=another-32-character-secret-change-this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Email Provider
# ============================================
# Options: console, gmail, sendgrid
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@example.com
APP_NAME=Chat Application

# Gmail API (when EMAIL_PROVIDER=gmail)
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# ============================================
# Dialogflow CX (Optional)
# ============================================
DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_AGENT_ID=
DIALOGFLOW_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================
# Google Cloud Storage (required for conversations + agent memory)
# ============================================
GCS_BUCKET_NAME=

# ============================================
# Redis (Refresh Token Storage)
# ============================================
# For local development: docker-compose up -d redis
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false
REDIS_CONNECT_TIMEOUT=2000
REDIS_COMMAND_TIMEOUT=1000

# ============================================
# Agent Memory / LLM (Vertex AI via model-agnostic wrapper)
# ============================================
# Options: vertex, mock
LLM_PROVIDER=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_MODEL=publishers/google/models/gemini-2.5-flash-lite

